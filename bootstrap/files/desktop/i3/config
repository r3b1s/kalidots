# i3 config - Omarchy-translated keybindings for Kali desktop
# Modifier: Super/Windows key (Mod4)

set $mod Mod4
set $term alacritty
set $bg-color #2f343f
set $text-color #f3f4f5
set $inactive-bg #2d2d2d
set $inactive-text #676e7d
set $urgent-bg #e53935
set $indicator #5294e2

# Font
font pango:monospace 10

# Terminal
bindsym $mod+Return exec --no-startup-id $term

# Launcher
bindsym $mod+space exec --no-startup-id rofi -show drun

# Close window
bindsym $mod+w kill

# Fullscreen toggle
bindsym $mod+f fullscreen toggle

# Focus bindings (hjkl, Omarchy-style)
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

# Move window bindings
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

# Resize bindings
bindsym $mod+ctrl+h resize shrink width 50 px
bindsym $mod+ctrl+l resize grow width 50 px
bindsym $mod+ctrl+k resize grow height 50 px
bindsym $mod+ctrl+j resize shrink height 50 px

# Layout and split
bindsym $mod+v split v
bindsym $mod+b split h
bindsym $mod+s layout stacking
bindsym $mod+e layout toggle split
bindsym $mod+t layout tabbed

# Floating toggle
bindsym $mod+Shift+space floating toggle

# Reload and restart i3
bindsym $mod+Shift+r restart
bindsym $mod+Shift+q exec "i3-nagbar -t warning -m 'Exit i3?' -b 'Yes' 'i3-msg exit'"

# Workspace names
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

# Switch to workspace
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

# Move container to workspace
bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

# Directory shortcuts (resolved at install time via sed)
bindsym $mod+ctrl+1 exec --no-startup-id alacritty --working-directory __TARGET_HOME__
bindsym $mod+ctrl+2 exec --no-startup-id alacritty --working-directory __TARGET_HOME__/Work
bindsym $mod+ctrl+3 exec --no-startup-id alacritty --working-directory __TARGET_HOME__/repos

# Startup
exec --no-startup-id feh --bg-fill __TARGET_HOME__/.wallpaper 2>/dev/null
exec --no-startup-id picom -b

# Bar (i3status fallback; i3status-rust configured in plan 02)
bar {
    position top
    status_command i3status
}

# Gaps and appearance
gaps inner 8
gaps outer 2
default_border pixel 2

# Window colors
# class                 border          backgr          text            indicator       child_border
client.focused          $bg-color       $bg-color       $text-color     $indicator      $bg-color
client.unfocused        $inactive-bg    $inactive-bg    $inactive-text  $inactive-bg    $inactive-bg
client.focused_inactive $inactive-bg    $inactive-bg    $inactive-text  $inactive-bg    $inactive-bg
client.urgent           $urgent-bg      $urgent-bg      $text-color     $urgent-bg      $urgent-bg
