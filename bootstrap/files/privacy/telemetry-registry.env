# Telemetry Registry - per-tool telemetry posture
# Format: TELEMETRY_TOOLNAME=STATUS:METHOD
# STATUS values: off (opted out), off_by_design (no telemetry exists), unknown (needs review), on (cannot disable)
# METHOD: how the opt-out is applied or why it's not needed
#
# This file is the documented artifact for PRIV-01.
# Stage 42-tools-privacy.sh reads this file and applies opt-outs (PRIV-02)
# or logs warnings for unknown entries (PRIV-03).

# --- Language Toolchains and Package Managers ---
TELEMETRY_GO=off:go_telemetry_off_command
TELEMETRY_GOLANG=off:go_telemetry_off_command
TELEMETRY_RUST=off_by_design:no_network_telemetry_in_rustc
TELEMETRY_RUSTUP=off_by_design:telemetry_disabled_by_default
TELEMETRY_PYTHON=off_by_design:no_network_telemetry
TELEMETRY_PYTHON_PIP=off_by_design:no_network_telemetry
TELEMETRY_PYTHON3_PIP=off_by_design:no_network_telemetry
TELEMETRY_PYTHON3_VENV=off_by_design:stdlib_virtualenv_support_no_telemetry
TELEMETRY_PIPX=off_by_design:no_network_telemetry
TELEMETRY_RUBY=off_by_design:no_network_telemetry
TELEMETRY_RUBY_DEV=off_by_design:development_headers_no_telemetry
TELEMETRY_RUBYGEMS=off_by_design:no_network_telemetry
TELEMETRY_BUILD_ESSENTIAL=off_by_design:compiler_toolchain_no_telemetry
TELEMETRY_GOPLS=off_by_design:inherits_go_toolchain_posture
TELEMETRY_PODMAN_TUI=off_by_design:open_source_no_telemetry
TELEMETRY_PWNTOOLS=off_by_design:open_source_no_telemetry
TELEMETRY_BUNDLER=off_by_design:no_network_telemetry
TELEMETRY_GUM=off_by_design:open_source_no_telemetry

