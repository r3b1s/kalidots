#!/usr/bin/env bash
set -euo pipefail

trap 'echo "[FATAL] Script exited unexpectedly at line ${LINENO} (exit code $?): ${BASH_COMMAND}" >&2' ERR

BOOTSTRAP_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# shellcheck source=../lib/log.sh
source "${BOOTSTRAP_ROOT}/lib/log.sh"
# shellcheck source=../lib/cli.sh
source "${BOOTSTRAP_ROOT}/lib/cli.sh"
# shellcheck source=../lib/state.sh
source "${BOOTSTRAP_ROOT}/lib/state.sh"
# shellcheck source=../lib/runner.sh
source "${BOOTSTRAP_ROOT}/lib/runner.sh"

require_root() {
  if [[ "${EUID}" -ne 0 ]]; then
    log_error "Run this installer as root."
    exit 1
  fi
}

ensure_bootstrap_deps() {
  local missing=()
  command -v jq >/dev/null 2>&1 || missing+=(jq)
  command -v git >/dev/null 2>&1 || missing+=(git)
  command -v curl >/dev/null 2>&1 || missing+=(curl)

  if [[ "${#missing[@]}" -gt 0 ]]; then
    log_info "Installing bootstrap dependencies: ${missing[*]}"
    apt-get update -qq
    apt-get install -y -qq "${missing[@]}"
  fi

  # gum is preferred for interactive prompts but not strictly required
  if ! command -v gum >/dev/null 2>&1; then
    log_info "Installing gum for interactive prompts"
    apt-get install -y -qq gum 2>/dev/null || log_warn "gum not available — falling back to plain prompts"
  fi
}

main() {
  require_root
  ensure_bootstrap_deps
  parse_cli_args "$@"

  local cleanup_only_requested=false

  if [[ "${#SELECTED_STAGE_IDS[@]}" -eq 1 && "${SELECTED_STAGE_IDS[0]}" == "bootstrap-user-cleanup" ]]; then
    cleanup_only_requested=true
  fi

  # Auto-detect bootstrap user from sudo if not explicitly provided
  if [[ "${cleanup_only_requested}" != "true" && -z "${BOOTSTRAP_USER:-}" && -n "${SUDO_USER:-}" ]]; then
    BOOTSTRAP_USER="${SUDO_USER}"
  fi

  if [[ "${#SELECTED_PROFILES[@]}" -eq 0 && "${#SELECTED_STAGE_IDS[@]}" -eq 0 ]]; then
    choose_profiles_interactive
  fi

  normalize_selected_profiles "${SELECTED_PROFILES[@]}"
  SELECTED_PROFILES=("${NORMALIZED_SELECTED_PROFILES[@]}")

  state_init
  if [[ -n "${BOOTSTRAP_USER:-}" ]]; then
    state_set_value '.runtime.bootstrap_user' "$(jq -Rn --arg value "${BOOTSTRAP_USER}" '$value')"
  fi
  state_set_run_selection \
    "$(join_by_comma "${SELECTED_PROFILES[@]}")" \
    "$(join_by_comma "${SELECTED_STAGE_IDS[@]}")"

  run_selected_stages

  if [[ "${cleanup_only_requested}" == "true" ]]; then
    if command -v gum >/dev/null 2>&1; then
      printf '\n'
      gum style \
        --border double \
        --border-foreground 203 \
        --padding "1 3" \
        --margin "1 0" \
        --bold \
        "  Bootstrap User Removed  "
      printf '\n'
      gum style --foreground 10 "  Cleanup stage applied and verified."
      printf '\n'
    else
      printf '\n'
      log_info "Bootstrap user cleanup complete."
      log_info "Cleanup stage applied and verified."
      printf '\n'
    fi
    return 0
  fi

  # Show completion summary
  local target_user_display="${TARGET_USER:-<target user>}"
  local cleanup_cmd="sudo $(realpath "$0") --stage bootstrap-user-cleanup"

  if command -v gum >/dev/null 2>&1; then
    printf '\n'
    gum style \
      --border double \
      --border-foreground 212 \
      --padding "1 3" \
      --margin "1 0" \
      --bold \
      "  Bootstrap complete!  "
    printf '\n'
    gum style --foreground 10 "  All selected profiles have been applied and verified."
    printf '\n'
    gum style --foreground 14 "  Next steps:"
    gum style "    1. Log out of this session"
    gum style "    2. Log in as $(gum style --bold --foreground 212 "${target_user_display}")"
    gum style "    3. Verify everything works as expected"
    printf '\n'
    gum style --foreground 11 "  Once you're satisfied, remove the bootstrap user by running:"
    printf '\n'
    gum style --foreground 8 "    ${cleanup_cmd}"
    printf '\n'
  else
    printf '\n'
    log_info "Bootstrap complete! All selected profiles applied and verified."
    log_info "Next steps:"
    log_info "  1. Log out of this session"
    log_info "  2. Log in as ${target_user_display}"
    log_info "  3. Verify everything works"
    log_info "Once satisfied, remove the bootstrap user:"
    log_info "  ${cleanup_cmd}"
    printf '\n'
  fi
}

main "$@"
