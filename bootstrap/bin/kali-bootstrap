#!/usr/bin/env bash
set -euo pipefail

BOOTSTRAP_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# shellcheck source=../lib/log.sh
source "${BOOTSTRAP_ROOT}/lib/log.sh"
# shellcheck source=../lib/cli.sh
source "${BOOTSTRAP_ROOT}/lib/cli.sh"
# shellcheck source=../lib/state.sh
source "${BOOTSTRAP_ROOT}/lib/state.sh"
# shellcheck source=../lib/runner.sh
source "${BOOTSTRAP_ROOT}/lib/runner.sh"

require_root() {
  if [[ "${EUID}" -ne 0 ]]; then
    log_error "Run this installer as root."
    exit 1
  fi
}

ensure_bootstrap_deps() {
  local missing=()
  command -v jq >/dev/null 2>&1 || missing+=(jq)
  command -v git >/dev/null 2>&1 || missing+=(git)
  command -v curl >/dev/null 2>&1 || missing+=(curl)

  if [[ "${#missing[@]}" -gt 0 ]]; then
    log_info "Installing bootstrap dependencies: ${missing[*]}"
    apt-get update -qq
    apt-get install -y -qq "${missing[@]}"
  fi

  # gum is preferred for interactive prompts but not strictly required
  if ! command -v gum >/dev/null 2>&1; then
    log_info "Installing gum for interactive prompts"
    apt-get install -y -qq gum 2>/dev/null || log_warn "gum not available — falling back to plain prompts"
  fi
}

main() {
  require_root
  ensure_bootstrap_deps
  parse_cli_args "$@"

  # Auto-detect bootstrap user from sudo if not explicitly provided
  if [[ -z "${BOOTSTRAP_USER:-}" && -n "${SUDO_USER:-}" ]]; then
    BOOTSTRAP_USER="${SUDO_USER}"
  fi

  if [[ "${#SELECTED_PROFILES[@]}" -eq 0 ]]; then
    choose_profiles_interactive
  fi

  normalize_selected_profiles "${SELECTED_PROFILES[@]}"
  SELECTED_PROFILES=("${NORMALIZED_SELECTED_PROFILES[@]}")

  state_init
  state_set_run_selection \
    "$(join_by_comma "${SELECTED_PROFILES[@]}")" \
    "$(join_by_comma "${SELECTED_STAGE_IDS[@]}")"

  run_selected_stages
}

main "$@"
